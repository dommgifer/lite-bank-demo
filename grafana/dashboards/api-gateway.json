{
  "uid": "litebank-api-gateway",
  "title": "Lite Bank - API Gateway",
  "description": "API Gateway metrics - entry point for all external requests",
  "tags": ["litebank", "gateway", "api"],
  "timezone": "browser",
  "editable": true,
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "id": 100,
      "title": "Gateway Overview",
      "type": "row",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 1,
      "title": "Total Requests/sec",
      "type": "stat",
      "gridPos": { "x": 0, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "expr": "sum(rate(litebank_calls_total{service_name=\"api-gateway\"}[1m]))",
          "legendFormat": "RPS"
        }
      ]
    },
    {
      "id": 2,
      "title": "Error Rate",
      "type": "gauge",
      "gridPos": { "x": 4, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "(sum(rate(litebank_calls_total{service_name=\"api-gateway\", status_code=~\"5..\"}[5m])) / sum(rate(litebank_calls_total{service_name=\"api-gateway\"}[5m]))) * 100",
          "legendFormat": "Error %"
        }
      ]
    },
    {
      "id": 3,
      "title": "P50 Latency",
      "type": "stat",
      "gridPos": { "x": 8, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(litebank_duration_milliseconds_bucket{service_name=\"api-gateway\"}[5m])) by (le))",
          "legendFormat": "P50"
        }
      ]
    },
    {
      "id": 4,
      "title": "P95 Latency",
      "type": "stat",
      "gridPos": { "x": 12, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 200 },
              { "color": "red", "value": 1000 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(litebank_duration_milliseconds_bucket{service_name=\"api-gateway\"}[5m])) by (le))",
          "legendFormat": "P95"
        }
      ]
    },
    {
      "id": 5,
      "title": "P99 Latency",
      "type": "stat",
      "gridPos": { "x": 16, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 2000 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(litebank_duration_milliseconds_bucket{service_name=\"api-gateway\"}[5m])) by (le))",
          "legendFormat": "P99"
        }
      ]
    },
    {
      "id": 6,
      "title": "Total Requests (1h)",
      "type": "stat",
      "gridPos": { "x": 20, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "sum(increase(litebank_calls_total{service_name=\"api-gateway\"}[1h]))",
          "legendFormat": "Total"
        }
      ]
    },
    {
      "id": 101,
      "title": "Traffic Analysis",
      "type": "row",
      "gridPos": { "x": 0, "y": 5, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 7,
      "title": "Request Rate Over Time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20
          }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "sum(rate(litebank_calls_total{service_name=\"api-gateway\"}[1m]))",
          "legendFormat": "Total RPS"
        },
        {
          "expr": "sum(rate(litebank_calls_total{service_name=\"api-gateway\", status_code=\"200\"}[1m]))",
          "legendFormat": "Successful (200)"
        },
        {
          "expr": "sum(rate(litebank_calls_total{service_name=\"api-gateway\", status_code=~\"[45]..\"}[1m]))",
          "legendFormat": "Errors (4xx/5xx)"
        }
      ]
    },
    {
      "id": 8,
      "title": "Latency Percentiles Over Time",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(litebank_duration_milliseconds_bucket{service_name=\"api-gateway\"}[5m])) by (le))",
          "legendFormat": "P50"
        },
        {
          "expr": "histogram_quantile(0.90, sum(rate(litebank_duration_milliseconds_bucket{service_name=\"api-gateway\"}[5m])) by (le))",
          "legendFormat": "P90"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(litebank_duration_milliseconds_bucket{service_name=\"api-gateway\"}[5m])) by (le))",
          "legendFormat": "P95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(litebank_duration_milliseconds_bucket{service_name=\"api-gateway\"}[5m])) by (le))",
          "legendFormat": "P99"
        }
      ]
    },
    {
      "id": 102,
      "title": "Route Analysis",
      "type": "row",
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 9,
      "title": "Request Rate by Route",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 15, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "expr": "sum(rate(litebank_calls_total{service_name=\"api-gateway\"}[1m])) by (http_route)",
          "legendFormat": "{{http_route}}"
        }
      ]
    },
    {
      "id": 10,
      "title": "Route Traffic Distribution",
      "type": "piechart",
      "gridPos": { "x": 12, "y": 15, "w": 6, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "values": ["percent"] },
        "pieType": "donut",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "sum(increase(litebank_calls_total{service_name=\"api-gateway\"}[1h])) by (http_route)",
          "legendFormat": "{{http_route}}"
        }
      ]
    },
    {
      "id": 11,
      "title": "Method Distribution",
      "type": "piechart",
      "gridPos": { "x": 18, "y": 15, "w": 6, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "GET" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "POST" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "PUT" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "DELETE" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "values": ["percent", "value"] },
        "pieType": "donut",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "sum(increase(litebank_calls_total{service_name=\"api-gateway\"}[1h])) by (http_method)",
          "legendFormat": "{{http_method}}"
        }
      ]
    },
    {
      "id": 103,
      "title": "Error Analysis",
      "type": "row",
      "gridPos": { "x": 0, "y": 23, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 12,
      "title": "Error Rate by Route",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 24, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "expr": "(sum(rate(litebank_calls_total{service_name=\"api-gateway\", status_code=~\"[45]..\"}[5m])) by (http_route) / sum(rate(litebank_calls_total{service_name=\"api-gateway\"}[5m])) by (http_route)) * 100",
          "legendFormat": "{{http_route}}"
        }
      ]
    },
    {
      "id": 13,
      "title": "Status Code Distribution",
      "type": "piechart",
      "gridPos": { "x": 12, "y": 24, "w": 6, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "200" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "201" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "400" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "401" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "403" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "404" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "500" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "502" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "503" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "values": ["percent", "value"] },
        "pieType": "donut",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "sum(increase(litebank_calls_total{service_name=\"api-gateway\"}[1h])) by (status_code)",
          "legendFormat": "{{status_code}}"
        }
      ]
    },
    {
      "id": 14,
      "title": "Errors Over Time by Status",
      "type": "timeseries",
      "gridPos": { "x": 18, "y": 24, "w": 6, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "stacking": { "mode": "normal" }
          }
        },
        "overrides": [
          { "matcher": { "id": "byRegexp", "options": "4.." }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byRegexp", "options": "5.." }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "sum(increase(litebank_calls_total{service_name=\"api-gateway\", status_code=~\"[45]..\"}[5m])) by (status_code)",
          "legendFormat": "{{status_code}}"
        }
      ]
    },
    {
      "id": 104,
      "title": "Route Performance",
      "type": "row",
      "gridPos": { "x": 0, "y": 32, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 15,
      "title": "P95 Latency by Route",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 33, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(litebank_duration_milliseconds_bucket{service_name=\"api-gateway\"}[5m])) by (le, http_route))",
          "legendFormat": "{{http_route}}"
        }
      ]
    },
    {
      "id": 16,
      "title": "Slowest Routes (P95)",
      "type": "bargauge",
      "gridPos": { "x": 12, "y": 33, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 200 },
              { "color": "red", "value": 1000 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "displayMode": "gradient"
      },
      "targets": [
        {
          "expr": "topk(10, histogram_quantile(0.95, sum(rate(litebank_duration_milliseconds_bucket{service_name=\"api-gateway\"}[5m])) by (le, http_route)))",
          "legendFormat": "{{http_route}}"
        }
      ]
    },
    {
      "id": 17,
      "title": "Top Routes by Traffic",
      "type": "table",
      "gridPos": { "x": 0, "y": 41, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value #RPS" },
            "properties": [
              { "id": "displayName", "value": "RPS" },
              { "id": "unit", "value": "reqps" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value #Error" },
            "properties": [
              { "id": "displayName", "value": "Error %" },
              { "id": "unit", "value": "percent" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 1 },
                    { "color": "red", "value": 5 }
                  ]
                }
              },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value #P95" },
            "properties": [
              { "id": "displayName", "value": "P95 (ms)" },
              { "id": "unit", "value": "ms" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 200 },
                    { "color": "red", "value": 1000 }
                  ]
                }
              },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value #Total" },
            "properties": [
              { "id": "displayName", "value": "Total (1h)" },
              { "id": "unit", "value": "short" }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "RPS", "desc": true }]
      },
      "transformations": [
        { "id": "merge", "options": {} }
      ],
      "targets": [
        {
          "expr": "sum(rate(litebank_calls_total{service_name=\"api-gateway\"}[1m])) by (http_route, http_method)",
          "refId": "RPS",
          "format": "table",
          "instant": true
        },
        {
          "expr": "(sum(rate(litebank_calls_total{service_name=\"api-gateway\", status_code=~\"[45]..\"}[5m])) by (http_route, http_method) / sum(rate(litebank_calls_total{service_name=\"api-gateway\"}[5m])) by (http_route, http_method)) * 100",
          "refId": "Error",
          "format": "table",
          "instant": true
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(litebank_duration_milliseconds_bucket{service_name=\"api-gateway\"}[5m])) by (le, http_route, http_method))",
          "refId": "P95",
          "format": "table",
          "instant": true
        },
        {
          "expr": "sum(increase(litebank_calls_total{service_name=\"api-gateway\"}[1h])) by (http_route, http_method)",
          "refId": "Total",
          "format": "table",
          "instant": true
        }
      ]
    }
  ],
  "schemaVersion": 39
}
