{
  "uid": "litebank-system-overview",
  "title": "Lite Bank - System Overview",
  "description": "Overall system health and performance metrics",
  "tags": ["litebank", "overview"],
  "timezone": "browser",
  "editable": true,
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "title": "Total Requests/sec",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "expr": "sum(rate(litebank_calls_total[1m]))",
          "legendFormat": "RPS"
        }
      ]
    },
    {
      "id": 2,
      "title": "Error Rate",
      "type": "gauge",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "(sum(rate(litebank_calls_total{status_code=~\"5..\"}[5m])) / sum(rate(litebank_calls_total[5m]))) * 100",
          "legendFormat": "Error %"
        }
      ]
    },
    {
      "id": 3,
      "title": "Avg Latency (P50)",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(litebank_duration_milliseconds_bucket[5m])) by (le))",
          "legendFormat": "P50"
        }
      ]
    },
    {
      "id": 4,
      "title": "P95 Latency",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 200 },
              { "color": "red", "value": 1000 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(litebank_duration_milliseconds_bucket[5m])) by (le))",
          "legendFormat": "P95"
        }
      ]
    },
    {
      "id": 5,
      "title": "P99 Latency",
      "type": "stat",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 2000 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(litebank_duration_milliseconds_bucket[5m])) by (le))",
          "legendFormat": "P99"
        }
      ]
    },
    {
      "id": 6,
      "title": "Active Services",
      "type": "stat",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "green", "value": 8 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "count(count by (service_name) (litebank_calls_total))",
          "legendFormat": "Services"
        }
      ]
    },
    {
      "id": 7,
      "title": "Request Rate by Service",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "expr": "sum(rate(litebank_calls_total[1m])) by (service_name)",
          "legendFormat": "{{service_name}}"
        }
      ]
    },
    {
      "id": 8,
      "title": "Error Rate by Service",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          },
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "expr": "(sum(rate(litebank_calls_total{status_code=~\"5..\"}[5m])) by (service_name) / sum(rate(litebank_calls_total[5m])) by (service_name)) * 100",
          "legendFormat": "{{service_name}}"
        }
      ]
    },
    {
      "id": 9,
      "title": "P95 Latency by Service",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(litebank_duration_milliseconds_bucket[5m])) by (le, service_name))",
          "legendFormat": "{{service_name}}"
        }
      ]
    },
    {
      "id": 10,
      "title": "Service Status",
      "type": "table",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "RPS" },
            "properties": [{ "id": "unit", "value": "reqps" }]
          },
          {
            "matcher": { "id": "byName", "options": "Error %" },
            "properties": [
              { "id": "unit", "value": "percent" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 1 },
                    { "color": "red", "value": 5 }
                  ]
                }
              },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "P95 (ms)" },
            "properties": [
              { "id": "unit", "value": "ms" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 200 },
                    { "color": "red", "value": 1000 }
                  ]
                }
              },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "RPS", "desc": true }]
      },
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "Value #RPS": "RPS",
              "Value #Error": "Error %",
              "Value #P95": "P95 (ms)"
            }
          }
        }
      ],
      "targets": [
        {
          "expr": "sum(rate(litebank_calls_total[1m])) by (service_name)",
          "legendFormat": "{{service_name}}",
          "refId": "RPS",
          "format": "table",
          "instant": true
        },
        {
          "expr": "(sum(rate(litebank_calls_total{status_code=~\"5..\"}[5m])) by (service_name) / sum(rate(litebank_calls_total[5m])) by (service_name)) * 100",
          "legendFormat": "{{service_name}}",
          "refId": "Error",
          "format": "table",
          "instant": true
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(litebank_duration_milliseconds_bucket[5m])) by (le, service_name))",
          "legendFormat": "{{service_name}}",
          "refId": "P95",
          "format": "table",
          "instant": true
        }
      ]
    },
    {
      "id": 11,
      "title": "Top 10 Endpoints by Traffic",
      "type": "table",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [{ "id": "unit", "value": "reqps" }]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Value", "desc": true }]
      },
      "targets": [
        {
          "expr": "topk(10, sum(rate(litebank_calls_total[5m])) by (http_route, service_name))",
          "legendFormat": "{{service_name}} - {{http_route}}",
          "format": "table",
          "instant": true
        }
      ]
    },
    {
      "id": 12,
      "title": "Requests by Status Code",
      "type": "piechart",
      "gridPos": { "x": 12, "y": 20, "w": 6, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "values": ["percent"] },
        "pieType": "donut",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "sum(increase(litebank_calls_total[1h])) by (status_code)",
          "legendFormat": "{{status_code}}"
        }
      ]
    },
    {
      "id": 13,
      "title": "Requests by Method",
      "type": "piechart",
      "gridPos": { "x": 18, "y": 20, "w": 6, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "values": ["percent"] },
        "pieType": "donut",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "sum(increase(litebank_calls_total[1h])) by (http_method)",
          "legendFormat": "{{http_method}}"
        }
      ]
    }
  ],
  "schemaVersion": 39
}
