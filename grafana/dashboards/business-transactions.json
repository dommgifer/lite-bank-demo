{
  "uid": "litebank-business-transactions",
  "title": "Lite Bank - Business Transactions",
  "description": "Banking business metrics: transfers, deposits, withdrawals, exchanges",
  "tags": ["litebank", "business", "transactions"],
  "timezone": "browser",
  "editable": true,
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "id": 100,
      "title": "Transfer Operations",
      "type": "row",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 1,
      "title": "Transfer Success Rate",
      "type": "gauge",
      "gridPos": { "x": 0, "y": 1, "w": 6, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 90 },
              { "color": "green", "value": 99 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "(sum(rate(litebank_calls_total{service_name=\"transfer-service\", status_code!=\"STATUS_CODE_ERROR\"}[5m])) / sum(rate(litebank_calls_total{service_name=\"transfer-service\"}[5m]))) * 100",
          "legendFormat": "Success %"
        }
      ]
    },
    {
      "id": 2,
      "title": "Transfers/min",
      "type": "stat",
      "gridPos": { "x": 6, "y": 1, "w": 4, "h": 3 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "expr": "sum(rate(litebank_calls_total{service_name=\"transfer-service\"}[1m])) * 60",
          "legendFormat": "Transfers"
        }
      ]
    },
    {
      "id": 3,
      "title": "Transfer P95 Latency",
      "type": "stat",
      "gridPos": { "x": 10, "y": 1, "w": 4, "h": 3 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 2000 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(litebank_duration_milliseconds_bucket{service_name=\"transfer-service\"}[5m])) by (le))",
          "legendFormat": "P95"
        }
      ]
    },
    {
      "id": 4,
      "title": "Failed Transfers (1h)",
      "type": "stat",
      "gridPos": { "x": 6, "y": 4, "w": 4, "h": 3 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "sum(increase(litebank_calls_total{service_name=\"transfer-service\", status_code=\"STATUS_CODE_ERROR\"}[1h])) or vector(0)",
          "legendFormat": "Failed"
        }
      ]
    },
    {
      "id": 5,
      "title": "Total Transfers (1h)",
      "type": "stat",
      "gridPos": { "x": 10, "y": 4, "w": 4, "h": 3 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "sum(increase(litebank_calls_total{service_name=\"transfer-service\"}[1h]))",
          "legendFormat": "Total"
        }
      ]
    },
    {
      "id": 6,
      "title": "Transfer Rate Over Time",
      "type": "timeseries",
      "gridPos": { "x": 14, "y": 1, "w": 10, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20
          }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "sum(rate(litebank_calls_total{service_name=\"transfer-service\", status_code!=\"STATUS_CODE_ERROR\"}[1m]))",
          "legendFormat": "Successful"
        },
        {
          "expr": "sum(rate(litebank_calls_total{service_name=\"transfer-service\", status_code=\"STATUS_CODE_ERROR\"}[1m]))",
          "legendFormat": "Failed"
        }
      ]
    },
