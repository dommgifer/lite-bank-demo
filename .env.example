# PostgreSQL Configuration
POSTGRES_DB=litebank
POSTGRES_USER=litebank_user
POSTGRES_PASSWORD=litebank_pass

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production-min-256-bits
JWT_EXPIRATION=86400

# OTEL Configuration
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_SERVICE_NAME=lite-bank-service
OTEL_RESOURCE_ATTRIBUTES=service.namespace=lite-bank-demo,deployment.environment=local

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Environment
ENVIRONMENT=local
